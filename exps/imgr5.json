{
  "prefix": "imagenetR5_r5_focus_p_proto",
  "dataset": "ImageNet_R",
  "data_path": "/data/lyc/data/imagenet-r",

  "memory_size": 0,
  "memory_per_class": 0,
  "fixed_memory": true,
  "shuffle": true,

  "init_cls": 40,
  "increment": 40,
  "total_sessions": 5,

  "model_name": "MACIL",
  "embd_dim": 768,
  "num_heads": 12,
  "rank": 32,

  "seed": [1993, 1996, 1997],
  "EPSILON": 1e-8,

  "batch_size": 48,
  "init_epoch": 20,
  "optim": "sgd",
  "init_lr": 0.01,
  "init_lr_decay": 0.1,
  "init_weight_decay": 0.0,

  "epochs": 10,
  "lrate": 0.01,
  "lrate_decay": 0.1,
  "weight_decay": 0.0,

  "scale": 20.0,
  "margin": 0.0,
  "num_workers": 8,

  "ca": true,
  "msc": true,
  "cc": true,
  "lamb_p": 0.4,

  "enable_replay": true,
  "replay_root": "exported_images_imagenetR5_r5_focus_p_proto",
  "replay_bs": 16,
  "replay_lambda": 0.07,
  "replay_ipc": 1,
  "replay_labels_are_new": true,

  "replay_influence_sampling": true,
  "replay_infl_update_interval": 20,
  "replay_infl_ema": 0.1,
  "replay_infl_eps": 0.05,
  "replay_infl_max_classes": 4,
  "replay_infl_min_weight": 0.001,

  "generate_replay": true,
  "replay_gen_per_class": 1,
  "replay_gen_steps": 220,
  "replay_gen_lr": 0.1,
  "replay_gen_size": 224,
  "replay_gen_pad": 8,
  "replay_gen_tv": 0.0001,
  "replay_gen_l2": 0.0001,
  "replay_gen_skip_existing": true,

  "replay_refine": true,
  "replay_refine_steps": 100,
  "replay_refine_lr": 0.03,
  "replay_refine_tv": 0.0001,
  "replay_refine_l2": 0.0001,
  "replay_refine_keep": 1.0,
  "replay_refine_pad": 8,
  "replay_refine_skip_missing": true,
  "replay_refine_max_classes": -1,
  "replay_gen_patch_weight": 0.05,
  "replay_refine_patch_weight": 0.03,
  "replay_patch_sample_k": 0,

  "replay_gm_mode": "featgrad",
  "replay_gradmatch": true,
  "replay_gradmatch_lambda": 0.3,
  "replay_gm_views": 2,

  "replay_gradmatch_real_batches": 4,
  "replay_gradmatch_real_bs_small": 8,
  "replay_gradmatch_ema": 0.2,

  "replay_gm_num_heads": 4,
  "replay_gm_soft": true,
  "replay_gm_soft_alpha": 0.2,
  "replay_gm_soft_tau": 0.5,

  "replay_proto_lambda": 0.15,

  "replay_inv_scale": 30.0,
  "replay_inv_temp": 1.0,

  "replay_teacher_kd": true,
  "replay_teacher_kd_lambda": 0.3,
  "replay_teacher_kd_T": 2.0,

  "lora_ortho_lambda": 0.05,
  "lora_ortho_mode": "B"
}
